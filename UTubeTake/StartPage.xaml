<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="UTubeTake.StartPage"
             Title="UTakePage"
             BackgroundColor="{StaticResource Background}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="48"/>
            <ColumnDefinition Width="{StaticResource ExternalSpace}"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="{StaticResource ExternalSpace}"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="{StaticResource ExternalSpace}"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="{StaticResource InternalSpace}"/>
            <RowDefinition Height="248"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{StaticResource ExternalSpace}"/>
        </Grid.RowDefinitions>

        <!--Nav-->
        <BoxView
           Grid.Column="0"
           Grid.Row="0"
           Grid.RowSpan="7"
            
           BackgroundColor="{StaticResource SideBackground}"/>

        <Image
            Grid.Column="0"
            Grid.Row="1"  
           
            HeightRequest="{StaticResource ImageSize_middle}" 
            WidthRequest="{StaticResource ImageSize_middle}"
            Margin="0"
            
            Aspect="AspectFit"
            Source="logo_icon.png"
               
            VerticalOptions="Center"
            HorizontalOptions="Center">
        </Image>

        <Image
            Grid.Column="0"
            Grid.Row="4"
   
            HeightRequest="{StaticResource ImageSize_middle}"
            WidthRequest="{StaticResource ImageSize_middle}"            
            
            HorizontalOptions="Center"
            VerticalOptions="End"            

            Aspect="AspectFit"
            Source="setting_icon.png">

            <Image.GestureRecognizers>
                <TapGestureRecognizer Tapped="SettingPageEvent"/>
            </Image.GestureRecognizers>
        </Image>
        <!--Nav-->

        
        <!--Window spliters-->
        <BoxView
            Grid.Column="1"
            Grid.Row="0"
            Grid.RowSpan="7"
            
            HorizontalOptions="Start"
            VerticalOptions="Fill"

            WidthRequest="1"
            
            BackgroundColor="{StaticResource Border}"
        />

        <BoxView
            Grid.Column="0"
            Grid.ColumnSpan="4"
            Grid.Row="0"
            
            HorizontalOptions="Fill"
            VerticalOptions="Start"

            HeightRequest="1"
            
            BackgroundColor="{StaticResource Border}"
        />
        <!--Window spliters-->

        
        <!--Top page-->
        <Grid
            Grid.Column="2"
            Grid.Row="1"
            
            Margin="0, 0, 0, 0">


            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="28"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="{StaticResource InternalSpace}"/>
                <ColumnDefinition Width="0.16*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <Border
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Grid.Row="0"
                
                BackgroundColor="{StaticResource MainBackground}"
                
                Stroke="{StaticResource Border}"
                StrokeThickness="2">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10,10,10,10"/>
                </Border.StrokeShape>

                <Grid ColumnDefinitions="28,*">
                    <Image
                        Grid.Column="0"
                        HeightRequest="{StaticResource ImageSize_small}"
                        WidthRequest="{StaticResource ImageSize_small}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        
                        Margin="0"
                        Aspect="AspectFit"
                        Source="link_icon.png">

                        <Image.Behaviors>
                            <toolkit:IconTintColorBehavior TintColor="{StaticResource TextSecondery}"/>
                        </Image.Behaviors>
                    </Image>

                    <Entry x:Name="linkEntry"
                        Grid.Column="1"
                        
                        FontFamily="Helvetica"
                        FontSize="{StaticResource FontSize_middle}"
                        
                        PlaceholderColor="{StaticResource TextSecondery}"
                        Placeholder="https://www.youtube.com/watch..."
                        ClearButtonVisibility="WhileEditing"/>

                </Grid>
            </Border>

            <Border
                Grid.Column="4"
                Grid.Row="0"
                
                Stroke="{StaticResource Border}"
                StrokeThickness="2">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10,10,10,10"/>
                </Border.StrokeShape>

                <Button
                     VerticalOptions="Fill"
                     HorizontalOptions="Fill"    
         
                     BorderColor="{StaticResource MainAccent}"
                     BackgroundColor="{StaticResource MainAccent}"
         
                     TextColor="{StaticResource Background}"
                     FontSize="20"
                     FontAttributes="Bold"
         
                     Text="Find"
         
                     Clicked="FindVideoEvent"/>

            </Border>
            
        </Grid>
        <!--Top page-->

        
        <!--Welcome view-->
        <HorizontalStackLayout x:Name="WelcomeView" IsVisible="False"
            Grid.Column="1"
            Grid.ColumnSpan="3"
            Grid.Row="2"
            Grid.RowSpan="3"
                                 
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="12">

            <Label
                FontSize="40"
                Text="Welcome dear user, I wait You ^.^"/>

        </HorizontalStackLayout>
        <!--Welcome view-->

        
        <!--Error view-->
        <Grid x:Name="ErrorView"
            Grid.Column="1"
            Grid.ColumnSpan="3"
            Grid.Row="2"
            Grid.RowSpan="3"
            
            IsVisible="True"
            
            Margin="5, 10, 5, 5"  
            
            ColumnDefinitions="Auto, *"
            RowDefinitions="auto,*,auto">

            <Label
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Grid.Row="0"
                
                HorizontalOptions="Center"
                
                FontSize="20"
                Text="Error detected!"
                />

            <Label
                Grid.Column="0"
                Grid.Row="1"
                
                HorizontalOptions="Center"
                BackgroundColor="Yellow"

                FontSize="20"
                Text="Error context:"/>

            <Label
                x:Name="ErrorCodeLabel"
                 Grid.Column="1"
                 Grid.Row="1"

                 FontSize="20"
                 Text=""/>

            <Label
                Grid.Column="0"
                Grid.Row="2"
                
                HorizontalOptions="Center"
                BackgroundColor="Red"

                HeightRequest="80"
                
                FontSize="20"
                Text="Resolve:"/>

            <Label
                x:Name="ErrorResolveLabel"
                 Grid.Column="1"
                 Grid.Row="2"

                 FontSize="20"
                 Text=""/>

        </Grid>
        <!--Welcome view-->


        <!--Loading view-->
        <HorizontalStackLayout x:Name="LoadingView"
            Grid.Column="1"
            Grid.ColumnSpan="3"
            Grid.Row="2"
            Grid.RowSpan="3"
                               
            HorizontalOptions="CenterAndExpand"
            VerticalOptions="CenterAndExpand"
            Spacing="12">

            <Ellipse x:Name="Dot_1"
                WidthRequest="24"
                HeightRequest="24">

                <Ellipse.Background>
                    <RadialGradientBrush Center="0.5,0.5" Radius="0.4">
                        <GradientStop Color="{StaticResource SubAccent}" Offset="0.0"/>
                        <GradientStop Color="{StaticResource MainAccent}" Offset="1.0"/>
                    </RadialGradientBrush>
                </Ellipse.Background>
            </Ellipse>

            <Ellipse x:Name="Dot_2"
                WidthRequest="24"
                HeightRequest="24">

                <Ellipse.Background>
                    <RadialGradientBrush Center="0.5,0.5" Radius="0.4">
                        <GradientStop Color="{StaticResource SubAccent}" Offset="0.0"/>
                        <GradientStop Color="{StaticResource MainAccent}" Offset="1.0"/>
                    </RadialGradientBrush>
                </Ellipse.Background>
            </Ellipse>

            <Ellipse x:Name="Dot_3"
                WidthRequest="24"
                HeightRequest="24">

                <Ellipse.Background>
                    <RadialGradientBrush Center="0.5,0.5" Radius="0.4">
                        <GradientStop Color="{StaticResource SubAccent}" Offset="0.0"/>
                        <GradientStop Color="{StaticResource MainAccent}" Offset="1.0"/>
                    </RadialGradientBrush>
                </Ellipse.Background>
            </Ellipse>

        </HorizontalStackLayout>
        <!--Loading view-->

        
        <!--Vido view-->
        <Grid x:Name="VideoView"
            IsVisible="False"
          
            Grid.Column="2"
            Grid.Row="3"
            
            HorizontalOptions="Fill"
            VerticalOptions="Fill"
              
            ColumnDefinitions="*,*"
            RowDefinitions="*,*">

            <Border
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Grid.Row="0"
                Grid.RowSpan="2"
                
                BackgroundColor="{StaticResource MainBackground}"
                
                Stroke="{StaticResource Border}"
                StrokeThickness="2">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10,10,10,10"/>
                </Border.StrokeShape>

                <HorizontalStackLayout
                    Padding="0"
                    Margin="0">

                    <Grid
                         Grid.Column="0"
                         Grid.Row="0"
                         Padding="0"
                         Margin="0"
                   
                         HorizontalOptions="Fill"
                         VerticalOptions="Fill"
                         
                         ColumnDefinitions="320"
                         RowDefinitions="180,*">

                        <Border
                            Grid.Column="0"
                            Grid.Row="0"
                            
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill"
                            Padding="0"
          
                            Stroke="{StaticResource MainAccent}"
                            StrokeThickness="0">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10,0,0,0"/>
                            </Border.StrokeShape>

                            <Image x:Name="imageVideo"
                                       Source="{Binding ImageBytes}"
                                       
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"     
                                       Aspect="AspectFit"/>
                        </Border>

                        <Button Clicked="DownloadImg"
                                Grid.Column="0"
                                Grid.Row="1"
                                
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill"
                                Margin="20,8,20,8"
                                Padding="0"
                                CornerRadius="8"
                                
                                BackgroundColor="{StaticResource MainAccent}"
                                ImageSource="link_icon.png"
                                ContentLayout="Left, 8"
                                TextColor="White"
                                Text="Download"/>
                        
                    </Grid>
                    
                    <VerticalStackLayout
                        Grid.Column="1"
                        Grid.Row="0"
                        HorizontalOptions="Fill"
                        
                        Spacing="10"
                        Margin="0"
                        Padding="10"
                        
                        BackgroundColor="{StaticResource MainBackground}">

                            <Label x:Name="VideoNameLabel"  
                                   HorizontalTextAlignment="Start" 
                                   VerticalTextAlignment="Center"
                            
                                   FontSize="28" 
                                   TextColor="White"
                                   Text="Name"/>

                            <Label x:Name="VideoAuthorLabel" 
                                   HorizontalTextAlignment="Start" 
                                   VerticalTextAlignment="Center"
                                   
                                   FontSize="20" 
                                   TextColor="White"
                                   Text="Author"/>

                            <Label x:Name="VideoDurationLabel" 
                                   HorizontalTextAlignment="Start" 
                                   VerticalTextAlignment="Center"
                               
                                   FontSize="20" 
                                   TextColor="White"
                                   Text="Duration"/>

                            <Label x:Name="VideoSizeLabel" 
                                   HorizontalTextAlignment="Start" 
                                   VerticalTextAlignment="Center"
                               
                                   FontSize="20" 
                                   TextColor="White"
                                   Text="Size"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>

            </Border>

        </Grid>



        <HorizontalStackLayout
                Grid.Column="3"
                Grid.ColumnSpan="2"
                Grid.Row="6"
                Margin="0,0,60,0"
                Padding="20"
                Spacing="20"
                HorizontalOptions="CenterAndExpand">

            <Picker WidthRequest="300"
                    TitleColor="White" TextColor="White"
                    BackgroundColor="{StaticResource MainBackground}"
                    x:Name="PickerQuality"
                    SelectedIndexChanged="PickerQuality_SelectedIndexChanged"
                    Title="Video quality"/>

            <Picker WidthRequest="300"
                    TitleColor="White" TextColor="White"
                    BackgroundColor="{StaticResource MainBackground}"
                    x:Name="PickerBitRate"
                    SelectedIndexChanged="PickerBitRate_SelectedIndexChanged"
                    Title="Sound quality"/>

            <Button WidthRequest="160" HeightRequest="40"
                    Margin="0,25,0,0"
                    CornerRadius="0"
                    BackgroundColor="{StaticResource MainAccent}"
                    TextColor="White"
                    Text="Download"
                    x:Name="DownloadVideoButton"
                    Clicked="DownloadVideoEvent"/>
        </HorizontalStackLayout>
        <!--Old Vido view-->
